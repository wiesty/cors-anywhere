{
  "name": "cors-anywhere",
  "version": "1.0.0",
  "description": "CORS Anywhere is a reverse proxy which adds CORS headers to the proxied request. Request URL is taken from the path",
  "license": "MIT",
  "author": "wiesty",
  "co-author": "Rob Wu <rob@robwu.nl>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wiesty/cors-anywhere.git"
  },
  "keywords": [
    "cors",
    "cross-domain",
    "http-proxy",
    "proxy"
  ],
  "main": "./lib/cors-anywhere.js",
  "bin": {
    "cors-anywhere": "./server.js"
  },
  "files": [
    "lib/",
    "test/",
    "server.js"
  ],
  "dependencies": {
    "http-proxy": "^1.18.1",
    "proxy-from-env": "^2.1.0"
  },
  "devDependencies": {
    "@sinonjs/fake-timers": "^15.3.0",
    "eslint": "^10.2.0",
    "mocha": "^11.7.5",
    "nock": "^14.0.12",
    "supertest": "^7.2.2"
  },
  "scripts": {
    "lint": "eslint .",
    "start": "node server.js",
    "test": "mocha ./test/test*.js --reporter spec"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
